{
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "test:ci": "pnpm -r test:ci",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write .",
    "prepublishOnly": "pnpm build",
    "changeset": "changeset",
    "changeset:version": "changeset version && pnpm install --no-frozen-lockfile",
    "release": "changeset publish",
    "docs:start": "pnpm --filter www dev",
    "docs:build": "pnpm --filter www build",
    "docs:preview": "pnpm --filter www preview",
    "docs:publish": "pnpm --filter www publish-pages"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@playwright/test": "^1.58.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": "7.29.6",
      "devalue": "5.8.1",
      "esbuild": "0.28.1",
      "fast-uri": "3.1.2",
      "js-yaml": "4.2.0",
      "lodash": "4.18.1",
      "picomatch@2": "2.3.2",
      "picomatch@4": "4.0.4",
      "postcss": "8.5.10",
      "smol-toml": "1.6.1",
      "undici": "7.24.0",
      "vite": "7.3.5",
      "ws": "8.21.0",
      "yaml": "2.8.3"
    }
  }
}
